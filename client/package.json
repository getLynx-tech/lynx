{
  "name": "Lynx",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "fmt": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "icons": "npx @svgr/cli --out-dir app/components/atoms/icons --typescript --no-prettier -- assets/icons && npm run fmt",
    "drizzle:generate": "npx drizzle-kit generate",
    "drizzle:migrate": "npx drizzle-kit migrate",
    "openapi:generate": "openapi-generator-cli generate -i '../server/cmd/docs/swagger.yaml' -g typescript-axios -o app/api/client/generated && prettier app/api/client/generated --write"
  },
  "dependencies": {
    "@eslint/css": "^1.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@react-router/node": "7.13.1",
    "@react-router/serve": "7.13.1",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-query-devtools": "^5.94.5",
    "@trpc/client": "^11.14.1",
    "@trpc/server": "^11.14.1",
    "@trpc/tanstack-react-query": "^11.14.1",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.13.6",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "eslint-plugin-react": "^7.37.5",
    "isbot": "^5.1.36",
    "lucide-react": "^1.7.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-router": "7.13.1",
    "shadcn": "^4.1.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.57.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "7.13.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
