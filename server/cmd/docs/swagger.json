            ],
            "properties": {
                "device_id": {
                    "type": "string"
                },
                "readings": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/request.Reading"
                    }
                }
            }
        },
        "request.Reading": {
            "type": "object",
